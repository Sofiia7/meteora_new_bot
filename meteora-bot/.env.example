# ─── Safety gate ──────────────────────────────────────────
# Если DRY_RUN=true — никаких реальных транзакций (только лог).
DRY_RUN=true
# Реальная торговля включается только при ОБОИХ: DRY_RUN=false И ENABLE_MAINNET_TRADING=true.
ENABLE_MAINNET_TRADING=false

# ─── Telegram ─────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
# Чат, куда бот ШЛЁТ уведомления.
TELEGRAM_CHAT_ID=
# Список chat_id (через запятую), которым РАЗРЕШЕНО управлять ботом.
# Если пусто — разрешено только TELEGRAM_CHAT_ID.
TELEGRAM_ALLOWED_CHAT_IDS=

# ─── Solana wallet & RPC ──────────────────────────────────
# Base58-encoded private key (Phantom export format).
SOLANA_PRIVATE_KEY=
RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
RPC_WS_URL=wss://mainnet.helius-rpc.com/?api-key=YOUR_KEY
HELIUS_API_KEY=

# ─── Scanner ──────────────────────────────────────────────
SCANNER_INTERVAL_MS=300000          # 5 минут
MIN_MARKET_CAP=250000
MIN_VOLUME_24H=1000000

# ─── Pool watcher ─────────────────────────────────────────
POOL_CHECK_INTERVAL_MS=30000        # 30 секунд
POOL_WATCH_TIMEOUT_MS=7200000       # 2 часа
# Сколько DLMM-пулов максимум показывать кнопками (остальное — ссылками).
POOL_BUTTONS_MAX=8

# ─── LP ───────────────────────────────────────────────────
LP_AMOUNT_SOL=0.1
MAX_POSITIONS=3
# Нижняя граница (-90% = "−90% от текущей цены"), верхняя (+100%).
PRICE_RANGE_LOWER=-90
PRICE_RANGE_UPPER=100
SWAP_SLIPPAGE_BPS=100               # 1%
# Буфер на rent + priority fees поверх LP_AMOUNT_SOL.
WALLET_SAFETY_BUFFER_SOL=0.1
WALLET_SAFETY_BUFFER_PCT=15

# ─── Security ─────────────────────────────────────────────
MIN_GMGN_FEES_SOL=30
TWITTER_BEARER_TOKEN=
# Score-based решение (Фаза 4): токен проходит, если нет hard-fail И score>=MIN_SECURITY_SCORE.
# Hard-fail = honeypot / активная mint|freeze authority / RugCheck danger.
MIN_SECURITY_SCORE=60
MAX_HOLDER_CONCENTRATION_PCT=50
# Как часто перепроверять security активной позиции (panic-фактор F4). Бережём API-лимиты.
SECURITY_RECHECK_MIN=5

# ─── Exit (take-profit signals) ───────────────────────────
EXIT_FEE_THRESHOLD=0.05             # 5% от позиции
BOLLINGER_PERIOD=20
BOLLINGER_STD_DEV=2

# Авто-стоп-лосс по цене — ВЫКЛ.
# Решение заказчика: паника ловится composite-детектором + ручной кнопкой.
ENABLE_PRICE_STOP_LOSS=false
EXIT_STOP_LOSS_PERCENT=35

# ─── Chart degradation (только предупреждение, не авто-выход) ──
RSI_DEGRADATION_THRESHOLD=40
VOLUME_DEGRADATION_RATIO=0.3

# ─── Composite panic-detector ─────────────────────────────
# Авто-выход срабатывает при ≥ PANIC_REQUIRED_FACTORS факторов одновременно в окне.
PANIC_REQUIRED_FACTORS=2
PANIC_TIME_WINDOW_MIN=15
PANIC_VOLUME_DROP_PCT=60
PANIC_RSI_THRESHOLD=40
PANIC_PRICE_DROP_FROM_ATH_PCT=50
PANIC_TVL_DROP_PCT=50               # F5: падение TVL пула от пика (Фаза 4)

# ─── ATH re-notification ──────────────────────────────────
# Повторное уведомление о токене срабатывает только если новый ATH выше прошлого уведомления на N%.
ATH_RENOTIFY_PCT=10
ATH_RENOTIFY_COOLDOWN_MIN=30

# ─── Chart health ─────────────────────────────────────────
MIN_HEALTH_SCORE=65
MAX_ATH_DISTANCE_PCT=30

# ─── AI-аналитик (локальная LLM, опционально) ─────────────
# OpenAI-совместимый эндпоинт (Ollama / LM Studio / vLLM). Никаких облачных вызовов.
# Выключено по умолчанию — бот полностью работает и без LLM.
AI_ENABLED=false
AI_BASE_URL=http://localhost:11434/v1   # Ollama по умолчанию
AI_MODEL=llama3.1
AI_API_KEY=                              # для локалки обычно не нужен
AI_TEMPERATURE=0.2
AI_MAX_TOKENS=220
AI_TIMEOUT_MS=20000

# ─── Ссылки на ресурсы (опц. override шаблонов) ───────────
# {ca}=mint токена, {pair}=адрес пары, {pool}=адрес DLMM-пула.
# Пусто = дефолт из кода. Переопредели, если ресурс сменит формат URL.
# LINK_GMGN_TPL=https://gmgn.ai/sol/token/{ca}
# LINK_BUBBLEMAPS_TPL=https://app.bubblemaps.io/sol/token/{ca}
# LINK_RUGCHECK_TPL=https://rugcheck.xyz/tokens/{ca}
# LINK_DEXSCREENER_TPL=https://dexscreener.com/solana/{pair}
# LINK_SOLSCAN_TPL=https://solscan.io/token/{ca}
# LINK_PHOTON_TPL=https://photon-sol.tinyurl.com/en/lp/{pair}
# LINK_METEORA_POOL_TPL=https://app.meteora.ag/dlmm/{pool}

# ─── Redis (опционально, кэш) ─────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Logging ──────────────────────────────────────────────
LOG_LEVEL=info
